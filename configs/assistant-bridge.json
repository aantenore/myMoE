{
  "schema_version": "2.0",
  "providers": {
    "local": {
      "id": "codex-oss-local",
      "mode": "local",
      "adapter": "codex_cli",
      "executable": "codex",
      "execution_scope": "device_only",
      "local_provider": "ollama",
      "codex_profile": "",
      "model": "qwen3:4b",
      "capabilities": [
        "analysis",
        "code",
        "filesystem",
        "shell",
        "tests"
      ],
      "tools": [
        "filesystem",
        "shell"
      ],
      "max_risk": "write_local",
      "sandbox": "workspace-write",
      "workspace_access": "read_write",
      "network_access": false,
      "timeout_seconds": 900,
      "launcher_args": [],
      "environment_allowlist": [],
      "extra_args": []
    },
    "premium": {
      "id": "codex-premium",
      "mode": "premium",
      "adapter": "codex_cli",
      "executable": "codex",
      "execution_scope": "remote",
      "codex_profile": "",
      "model": "gpt-5.6-sol",
      "capabilities": [
        "analysis",
        "code",
        "complex_reasoning",
        "filesystem",
        "large_context",
        "multimodal",
        "shell",
        "tests",
        "web"
      ],
      "tools": [
        "filesystem",
        "shell",
        "web"
      ],
      "max_risk": "write_local",
      "sandbox": "workspace-write",
      "workspace_access": "read_write",
      "network_access": true,
      "timeout_seconds": 900,
      "launcher_args": [],
      "environment_allowlist": [],
      "extra_args": []
    }
  },
  "profiles": {
    "economy": {
      "initial_route": "local",
      "remote_allowed": true,
      "explicit_remote_opt_in": false,
      "max_premium_calls": 1
    },
    "balanced": {
      "initial_route": "local_then_verify",
      "remote_allowed": true,
      "explicit_remote_opt_in": false,
      "max_premium_calls": 1
    },
    "quality": {
      "initial_route": "premium",
      "remote_allowed": true,
      "explicit_remote_opt_in": false,
      "max_premium_calls": 1
    },
    "privacy": {
      "initial_route": "local_then_verify",
      "remote_allowed": false,
      "explicit_remote_opt_in": true,
      "max_premium_calls": 1
    },
    "offline": {
      "initial_route": "local",
      "remote_allowed": false,
      "explicit_remote_opt_in": false,
      "max_premium_calls": 0
    }
  },
  "verification": {
    "output_checks": [
      {
        "id": "assistant-output-nonempty",
        "type": "nonempty",
        "description": "The assistant produced a final result."
      },
      {
        "id": "assistant-output-honest",
        "type": "excludes",
        "description": "Known failure language cannot be mistaken for completion.",
        "values": [
          "I could not complete",
          "I couldn't complete",
          "unable to complete",
          "failed to complete",
          "tests are failing",
          "verification failed"
        ]
      }
    ],
    "command_verifiers": [
      {
        "id": "git-diff-contract",
        "argv": ["git", "diff", "--check", "HEAD", "--", "."],
        "timeout_seconds": 60,
        "purpose": "hygiene",
        "execution_boundary": "disposable_workspace",
        "network_policy": "not_enforced",
        "environment_allowlist": [],
        "required_for_capabilities": ["code", "tests"],
        "required_for_tools": ["filesystem", "shell"],
        "required_for_risks": ["write_local"]
      },
      {
        "id": "project-test-suite",
        "argv": ["{python}", "-m", "unittest", "discover", "-s", "tests", "-v"],
        "timeout_seconds": 900,
        "purpose": "task",
        "execution_boundary": "disposable_workspace",
        "network_policy": "not_enforced",
        "environment_allowlist": [],
        "required_for_capabilities": [],
        "required_for_tools": [],
        "required_for_risks": []
      }
    ],
    "external_verifiers": [
      {
        "id": "focused-tests",
        "verifier": "test-runner",
        "spec_sha256": "bbd7d15a562a8eb4ffc6b52cf6f89855589c5047e89d5d22c23645e912ff1e30"
      }
    ],
    "independent_required_for": {
      "capabilities": ["code", "tests"],
      "tools": ["filesystem", "shell"],
      "risks": ["write_local"]
    }
  },
  "capsule": {
    "max_chars": 8000,
    "max_objective_chars": 3000,
    "max_constraint_chars": 1000,
    "max_diff_chars": 2500,
    "secret_redaction": {
      "require_residual_assurance": true,
      "residual_plugins": [
        "AWSKeyDetector",
        "AzureStorageKeyDetector",
        "Base64HighEntropyString",
        "BasicAuthDetector",
        "DiscordBotTokenDetector",
        "GitHubTokenDetector",
        "GitLabTokenDetector",
        "HexHighEntropyString",
        "JwtTokenDetector",
        "KeywordDetector",
        "NpmDetector",
        "OpenAIDetector",
        "PrivateKeyDetector",
        "PypiTokenDetector",
        "SendGridDetector",
        "SlackDetector",
        "SquareOAuthDetector",
        "StripeDetector",
        "TelegramBotTokenDetector",
        "TwilioKeyDetector"
      ]
    }
  },
  "runtime": {
    "require_tree_isolation": true,
    "require_psutil": true,
    "stdin_limit_bytes": 8388608,
    "stdout_limit_bytes": 2097152,
    "stderr_limit_bytes": 2097152,
    "cleanup_grace_seconds": 0.25,
    "cleanup_kill_seconds": 0.75
  },
  "state": {
    "ledger_path": "work/runtime/assistant-bridge-state.json",
    "namespace": "assistant-bridge-v2",
    "confirmation_ttl_seconds": 300,
    "lock_timeout_seconds": 5,
    "stale_lock_seconds": 120,
    "budget_retention_seconds": 7776000,
    "max_budget_entries": 4096,
    "confirmation_retention_seconds": 86400,
    "max_confirmation_entries": 4096,
    "budget_lease_ttl_seconds": 60
  },
  "workspace": {
    "max_files": 5000,
    "max_total_bytes": 268435456,
    "max_file_bytes": 67108864,
    "ignored_paths": [],
    "transaction_state_dir": "work/runtime/assistant-transactions",
    "transaction_lock_ttl_seconds": 120
  }
}
