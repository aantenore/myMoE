{
  "execution": {
    "max_scope": "private_mesh",
    "allowed_scopes": ["device_only", "private_mesh"],
    "allow_scope_widening": false
  },
  "routing": {
    "top_k": 1,
    "fallback_order": [],
    "aggregation": "best"
  },
  "experts": [
    {
      "id": "private_mesh_general",
      "provider": "openai_compatible",
      "base_url": "http://127.0.0.1:8080/v1",
      "execution": {
        "scope": "private_mesh",
        "transport": "mesh_llm"
      },
      "model": "replace-with-mesh-model-id",
      "role": "private-mesh-general-purpose",
      "weight": 1.0,
      "timeout_seconds": 90,
      "params": {
        "temperature": 0.2,
        "max_tokens": 1024
      }
    }
  ],
  "rules": []
}
