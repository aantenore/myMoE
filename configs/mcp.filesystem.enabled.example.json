{
  "servers": [
    {
      "name": "filesystem",
      "description": "Example enabled local filesystem MCP bridge. Use only for trusted local testing.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true,
      "risk_class": "write_local",
      "capabilities": ["resources", "tools"],
      "transport": "stdio",
      "cwd": ".",
      "env": {},
      "timeout_seconds": 8
    }
  ]
}
