{
  "name": "myMoE",
  "mode": "local_model_required",
  "default_moe_config": "moe.json",
  "language": {
    "mode": "auto",
    "respond_in_user_language": true,
    "supported": ["auto", "it", "en", "fr", "de", "es", "pt", "nl", "pl", "ar", "hi", "ja", "ko", "zh"]
  },
  "runtime": {
    "auto_configure": false,
    "preferred_backends": {},
    "model_cache_dir": "~/.cache/huggingface",
    "work_dir": "work/runtime",
    "context_policy_config": "context-policy.json",
    "context_policy_profile": "default",
    "profile_dir": ".",
    "evaluation_dir": "experiments",
    "cron_auto_run": false,
    "cron_poll_seconds": 300,
    "cron_confirm_writes": false
  },
  "extensions": {
    "plugins_dir": "plugins",
    "skills_dir": "skills",
    "tools_config": "tools.json",
    "mcp_config": "mcp.playwright-browser.json",
    "cron_config": "cron.json"
  },
  "permissions": {
    "default_write_policy": "approval_required",
    "allow_process_execution": true,
    "assistant_bridge_execution_policy": "disabled",
    "connector_install_policy": "approval_required",
    "external_communication_policy": "draft_only"
  },
  "gateway": {
    "enabled": true,
    "model_alias": "mymoe",
    "max_request_bytes": 8388608,
    "max_response_bytes": 33554432,
    "allow_non_loopback": false,
    "api_key_env": ""
  }
}
